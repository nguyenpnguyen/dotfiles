{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "edit": "ask",
        "bash": "ask"
    },
    "agent": {
        "build": {
            "mode": "primary",
            "model": "github-copilot/gpt-5.4-mini",
            "temperature": 0.2,
            "tools": {
                "write": true,
                "edit": true,
                "bash": true
            }
        },
        "plan": {
            "mode": "primary",
            "model": "github-copilot/claude-sonnet-4.6",
            "tools": {
                "write": false,
                "edit": false,
                "bash": false
            }
        },
        "general": {
            "mode": "subagent",
            "model": "github-copilot/gpt-5-mini",
            "temperature": 0.3
        },
        "explore": {
            "mode": "subagent",
            "model": "github-copilot/gpt-5-mini",
            "temperature": 0.7
        },
    }
}
